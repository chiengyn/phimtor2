# --- Viewer server (public, read-only) ---
VIEWER_PORT=8082

# Support Discord invite link, surfaced in the site header/footer.
# Leave empty to hide the link.
VIEWER_DISCORD_URL=https://discord.gg/PhaE6DgnC

# --- MySQL (shared with the admin service) ---
# Either set the individual DB_* values or a full MYSQL_DSN (which overrides them).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=phimtor
DB_PASSWORD=phimtor
DB_NAME=phimtor
# MYSQL_DSN=phimtor:phimtor@tcp(127.0.0.1:3306)/phimtor?parseTime=true&charset=utf8mb4

# --- Streamer manager (control plane) ---
# The viewer adds torrents server-to-server via the manager (internal URL + bearer
# token). The manager picks a streamer and returns its public URL, which the
# prepare response hands to the browser for stats + stream directly — so there is
# no single static public streamer URL anymore. MANAGER_INTERNAL_TOKEN must match
# the manager's MANAGER_INTERNAL_TOKEN; empty disables it.
MANAGER_INTERNAL_URL=http://localhost:8083
MANAGER_INTERNAL_TOKEN=

# Seconds a watch session may go silent before the viewer treats the tab as gone
# and drops its torrent (via the manager) to free streamer resources. The watch
# page also beacons a leave on page hide for an instant drop; this TTL is the
# backstop for crashed tabs / dead networks. Keep it well above the page's 10s
# heartbeat interval so a couple of missed beats don't evict an active viewer.
WATCH_HEARTBEAT_TTL=30

# --- Subtitle storage (READ-ONLY; must point at the SAME storage admin writes to) ---
SUBTITLE_STORAGE_BACKEND=local
# For local: this MUST be the same directory the admin writes subtitles to
# (a shared volume under compose).
SUBTITLE_STORAGE_DIR=./data/subtitles
# For s3: set the same bucket the admin uses. Secrets are env-only.
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_USE_SSL=true
