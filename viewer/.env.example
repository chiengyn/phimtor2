# --- Viewer server (public, read-only) ---
VIEWER_PORT=8082

# --- MySQL (shared with the admin service) ---
# Either set the individual DB_* values or a full MYSQL_DSN (which overrides them).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=phimtor
DB_PASSWORD=phimtor
DB_NAME=phimtor
# MYSQL_DSN=phimtor:phimtor@tcp(127.0.0.1:3306)/phimtor?parseTime=true&charset=utf8mb4

# --- Streamer service ---
# Public URL must be reachable from the BROWSER (stats + stream only).
# Internal URL is used by the viewer server to add torrents (e.g. http://streamer:8080
# under compose). In local dev the two are usually identical.
STREAMER_PUBLIC_URL=http://localhost:8080
STREAMER_INTERNAL_URL=http://localhost:8080

# --- Subtitle storage (READ-ONLY; must point at the SAME storage admin writes to) ---
SUBTITLE_STORAGE_BACKEND=local
# For local: this MUST be the same directory the admin writes subtitles to
# (a shared volume under compose).
SUBTITLE_STORAGE_DIR=./data/subtitles
# For s3: set the same bucket the admin uses. Secrets are env-only.
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_USE_SSL=true
