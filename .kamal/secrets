# Kamal resolves each secret below from the SHELL ENVIRONMENT at deploy time.
# This file is COMMITTED on purpose (the manual CD workflow needs it), so it must
# contain ONLY ${VAR} references — NEVER literal secret values. The real values
# come from the environment: a gitignored .env locally, or GitHub Actions secrets
# in CI (.github/workflows/deploy.yml).
#
# Provide the values before running kamal, e.g. from a gitignored .env:
#
#     set -a && source .env && set +a
#     kamal deploy                              # admin
#     kamal deploy -c config/deploy.viewer.yml
#     kamal deploy -c config/deploy.streamer.yml
#
# ...or by exporting them in your CI job. See .kamal/secrets.example for the
# full list and how to obtain each one.

# GitHub PAT with write:packages, for pushing/pulling ghcr.io images.
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}

# Admin app
ADMIN_PASSWORD=${ADMIN_PASSWORD}
TMDB_API_KEY=${TMDB_API_KEY}
OPENSUBTITLES_API_KEY=${OPENSUBTITLES_API_KEY}
SUBSOURCE_API_KEY=${SUBSOURCE_API_KEY}

# MySQL (shared by admin + viewer). MYSQL_PASSWORD mirrors DB_PASSWORD so the
# app user's password and the accessory's user password stay in sync.
DB_PASSWORD=${DB_PASSWORD}
MYSQL_PASSWORD=${DB_PASSWORD}
MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD}
