# Reference list of the values the Kamal configs need. Copy them into a
# gitignored .env (and/or your CI secret/variable store), then deploy with:
#
#     set -a && source .env && set +a && kamal deploy --skip-push
#
# Secrets are resolved through the committed .kamal/secrets file; the host
# config below is read directly by the configs via ERB <%= ENV[...] %>.

# --- Host config (NOT secret — these are public infra values) ---
SERVER_IP=203.0.113.10                    # the host running all the services
ADMIN_HOST=admin.yourdomain.com           # admin proxy domain
VIEWER_HOST=yourdomain.com                # public site domain
# Each streamer instance needs its OWN browser-reachable domain (the manager
# hands these out for direct stats/stream). Add STREAMER3_HOST etc. per instance.
STREAMER1_HOST=stream1.yourdomain.com     # streamer instance 1 API domain
STREAMER2_HOST=stream2.yourdomain.com     # streamer instance 2 API domain
# Manager API domain — token-gated, public so streamers on OTHER servers can
# register. Same-host services use the internal alias instead; only remote
# streamers need this. Needs a DNS record before public HTTPS works.
MANAGER_HOST=manager.yourdomain.com

# --- Container registry (ghcr.io) ---
# A GitHub Personal Access Token (classic) with the `write:packages` scope, or a
# fine-grained token with Packages: read+write. Create at:
#   https://github.com/settings/tokens
KAMAL_REGISTRY_PASSWORD=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Admin app ---
ADMIN_PASSWORD=change-me                 # HTTP Basic auth password
TMDB_API_KEY=                            # themoviedb.org v3 API key
OPENSUBTITLES_API_KEY=                   # opensubtitles.com v1 API key (subtitles)
SUBSOURCE_API_KEY=                       # subsource.net API key (alt subtitle source)

# --- MySQL accessory (shared by admin + viewer) ---
DB_PASSWORD=change-me                    # app user "phimtor" password
MYSQL_ROOT_PASSWORD=change-me-too        # MySQL root password

# --- Streamer control plane (manager ⇄ admin/viewer ⇄ streamers) ---
# Shared bearer tokens for the internal-only API. Generate each with:
#   openssl rand -hex 32
MANAGER_REGISTER_TOKEN=change-me         # streamers → manager (registration)
MANAGER_INTERNAL_TOKEN=change-me         # admin/viewer → manager (control)
STREAMER_INTERNAL_TOKEN=change-me        # manager → streamers (internal routes)

# --- Optional: OpenSubtitles login (raises daily download quota) ---
# To use, also uncomment them in config/deploy.yml (admin) and .kamal/secrets.
# OPENSUBTITLES_USERNAME=
# OPENSUBTITLES_PASSWORD=
