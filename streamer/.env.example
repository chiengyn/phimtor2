# HTTP server port
PORT=8080

# Torrent data directory
DATA_DIR=./data

# Streaming readahead in MB
READAHEAD_MB=16

# Storage backend: prefix-cache or capped-sqlite
STORAGE_MODE=prefix-cache

# Bytes pinned at the start of each video file, in MB
PREFIX_MB=32

# Bounded cache budget for the bulk, in MB
CACHE_MB=2048
