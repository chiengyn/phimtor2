# HTTP server port
PORT=8080

# Torrent data directory
DATA_DIR=./data

# Streaming readahead in MB
READAHEAD_MB=16

# Storage backend: prefix-cache or capped-sqlite
STORAGE_MODE=prefix-cache

# Bytes pinned at the start of each video file, in MB
PREFIX_MB=32

# Bounded cache budget for the bulk, in MB
CACHE_MB=2048

# OpenSubtitles API key — required to enable subtitle search/download
OPENSUBTITLES_API_KEY=

# User-Agent sent to the OpenSubtitles API (your app name + version)
OPENSUBTITLES_USER_AGENT=phimtor2 v1.0

# Optional OpenSubtitles login — raises the per-day download quota
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
