# HTTP server port
PORT=8080

# Torrent data directory
DATA_DIR=./data

# Max streaming readahead per reader in MB (scaled down as concurrent readers rise)
READAHEAD_MB=16

# Storage backend: prefix-cache, capped-sqlite or download-all.
#
# prefix-cache streams around each viewer's playhead with a bounded disk budget,
# but only ever fetches a window — if the swarm decays during a long watch, the
# later parts of the file may have no seeders left by the time they're needed.
# download-all fetches the ENTIRE torrent the moment metadata arrives (banking
# it while seeders still exist) and reclaims space by deleting pieces every
# viewer has already watched (see KEEP_BEHIND_MB). Peak disk per torrent is the
# full file size.
STORAGE_MODE=prefix-cache

# Bytes pinned at the start of each video file, in MB
PREFIX_MB=32

# Bytes pinned at the end of each video file, in MB. Non-faststart MP4s keep their
# moov atom (the index the player needs before it can render a frame) at the tail,
# which the browser range-requests first — pinning it avoids a cold-start stall.
SUFFIX_MB=8

# Bounded cache budget for the bulk, in MB. Raising this lets more concurrent
# viewers be served from disk without re-downloading from the swarm.
# (prefix-cache mode only; download-all has no cache budget.)
CACHE_MB=2048

# download-all mode only: rewind margin for the watched-piece sweep. Pieces are
# deleted only once they fall this many MB behind EVERY viewer's playhead, so
# small back-seeks replay from disk. Seeking further back re-downloads from the
# swarm on demand.
KEEP_BEHIND_MB=256

# Peer connections per torrent. Higher fills a hot torrent's cache from the swarm
# faster (library default is 50).
MAX_CONNS=200

# Keep every piece of a torrent that currently has a viewer (trades disk for
# concurrent capacity, so late joiners never re-hit the swarm). Default off keeps
# the strict space-saving behavior.
RETAIN_HOT=false

# Drop torrents that go unstreamed for this many minutes, freeing their disk
# blobs and peer connections. 0 disables (torrents stay until removed via the API).
IDLE_TTL_MIN=30

# Global in-flight/unverified bytes cap across ALL torrents, in MB. The library
# default (64) is a single shared budget that one stalled torrent can exhaust,
# starving every other torrent of piece requests. 0 disables that cap (default).
MAX_UNVERIFIED_MB=0

# Drop a torrent a viewer is waiting on that downloads nothing with no connected
# seeders for this many seconds (a dead swarm), so it stops pinning a peer slot
# and an open reader. Progress, completion, or a connected seeder resets the
# clock, so slow/paused playback is never dropped. 0 disables.
STALL_TIMEOUT_SEC=120

# --- Manager / control-plane wiring (ALL REQUIRED — the streamer no longer runs
# --- standalone; it must register with a manager and be approved before serving) ---
#
# The streamer's control-plane credential is NOT configured here: on first boot it
# self-generates a token and persists it to <DATA_DIR>/identity. The manager pins
# that token's fingerprint when an operator approves this streamer in the admin
# Streamers dashboard, and presents it on every internal call thereafter.

# Where this streamer registers itself. Required.
MANAGER_URL=

# Shared join token sent when registering (must match the manager's
# MANAGER_REGISTER_TOKEN). Anti-spam gate on /register only. Required.
MANAGER_REGISTER_TOKEN=

# Stable identity for this instance in the manager's registry. Keep it stable
# across redeploys (with a persistent DATA_DIR) so the pinned approval survives;
# otherwise a redeploy looks like a brand-new pending streamer. Defaults to the
# container hostname.
STREAMER_INSTANCE_ID=

# What this streamer advertises to the manager: the internal URL the manager uses
# server-to-server, and the public URL browsers use for stats/stream directly.
# Both required.
STREAMER_ADVERTISE_INTERNAL_URL=
STREAMER_ADVERTISE_PUBLIC_URL=
