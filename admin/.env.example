# --- Admin server ---
ADMIN_PORT=8081

# HTTP Basic auth (required). The browser prompts for these.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- TMDB (themoviedb.org) ---
# v3 API key (required to enable importing).
TMDB_API_KEY=
# Primary language; falls back to TMDB_FALLBACK_LANGUAGE for empty fields.
TMDB_LANGUAGE=vi-VN
TMDB_FALLBACK_LANGUAGE=en-US

# --- MySQL ---
# Either set the individual DB_* values or a full MYSQL_DSN (which overrides them).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=phimtor
DB_PASSWORD=phimtor
DB_NAME=phimtor
# MYSQL_DSN=phimtor:phimtor@tcp(127.0.0.1:3306)/phimtor?parseTime=true&charset=utf8mb4

# Used by docker-compose for the MySQL container's root password.
MYSQL_ROOT_PASSWORD=root

# --- Streamer (torrent watch page) ---
# Base URL of the streamer service. Injected into the watch page so the browser
# talks to the streamer's torrent/stream API directly (must be reachable from
# the browser, not just from the admin server).
STREAMER_URL=http://localhost:8080

# --- OpenSubtitles (subtitle search on the watch page) ---
# v1 API key — required to enable subtitle search/download.
OPENSUBTITLES_API_KEY=
# User-Agent sent to the OpenSubtitles API (your app name + version).
OPENSUBTITLES_USER_AGENT=phimtor2 v1.0
# Optional login — raises the per-day download quota.
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
