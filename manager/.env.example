# HTTP server port
MANAGER_PORT=8083

# Shared join token that streamers send when self-registering. Acts as an
# anti-spam gate on the register endpoint only — a streamer's actual identity is
# its own self-generated token, pinned when an operator approves it. Must match
# each streamer's MANAGER_REGISTER_TOKEN. Empty disables the gate (dev only).
MANAGER_REGISTER_TOKEN=

# Bearer token that admin/viewer send on the control routes the manager exposes.
# Empty disables the gate (dev only).
MANAGER_INTERNAL_TOKEN=

# Directory for the persisted streamer enrollment allow-list
# (<dir>/enrollments.json). Must be on a durable volume so approvals survive
# restarts; otherwise every streamer returns to "pending" after a redeploy.
MANAGER_STATE_DIR=./data

# Seconds without a heartbeat before an instance is dropped from the registry.
# Keep it well above the streamer's 10s heartbeat interval.
MANAGER_HEARTBEAT_TTL=30

# Seconds between owner-map reconciles (fan-out list of every instance).
MANAGER_RECONCILE_INTERVAL=60

# Placement strategy for new torrents: least-torrents, least-bandwidth, or
# round-robin. least-bandwidth balances by each streamer's live viewer egress
# rate — HTTP bytes/sec served to browsers (polled every
# MANAGER_RECONCILE_INTERVAL) — falling back to torrent count when the fleet is
# idle.
MANAGER_LB_STRATEGY=least-torrents

# Per-request timeout for control-plane calls to streamers, in seconds.
MANAGER_FORWARD_TIMEOUT=10
