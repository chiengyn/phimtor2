# HTTP server port
MANAGER_PORT=8083

# Shared bearer token that streamers send when self-registering. Must match each
# streamer's MANAGER_REGISTER_TOKEN. Empty disables the gate (dev only).
MANAGER_REGISTER_TOKEN=

# Bearer token that admin/viewer send on the control routes the manager exposes.
# Empty disables the gate (dev only).
MANAGER_INTERNAL_TOKEN=

# Bearer token the manager sends to streamers' internal routes (must match each
# streamer's STREAMER_INTERNAL_TOKEN). Defaults to MANAGER_INTERNAL_TOKEN when
# unset, so a single secret covers the whole internal control plane.
STREAMER_INTERNAL_TOKEN=

# Seconds without a heartbeat before an instance is dropped from the registry.
# Keep it well above the streamer's 10s heartbeat interval.
MANAGER_HEARTBEAT_TTL=30

# Seconds between owner-map reconciles (fan-out list of every instance).
MANAGER_RECONCILE_INTERVAL=60

# Placement strategy for new torrents: least-torrents or round-robin.
MANAGER_LB_STRATEGY=least-torrents

# Per-request timeout for control-plane calls to streamers, in seconds.
MANAGER_FORWARD_TIMEOUT=10
